# OpenToken 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ========================================
# 网关 API Key 配置
# ========================================
# 优先从环境变量读取，不存在时自动生成并打印到日志
# OPENTOKEN_API_KEY=your-api-key-here

# ========================================
# 存储后端配置
# ========================================
# 存储后端类型: "local" (默认) 或 "s3"
OPENTOKEN_STORAGE_BACKEND=local

# ========================================
# S3 兼容对象存储配置（当 OPENTOKEN_STORAGE_BACKEND=s3 时需要）
# ========================================
# S3 端点 URL（可选，根据实际情况填写）
# OPENTOKEN_S3_ENDPOINT=http://localhost:9000

# S3 区域（默认: us-east-1）
# OPENTOKEN_S3_REGION=us-east-1

# 存储桶名称（必填）
# OPENTOKEN_S3_BUCKET=opentoken-data

# Access Key ID（必填）
# OPENTOKEN_S3_ACCESS_KEY=your-access-key

# Secret Access Key（必填）
# OPENTOKEN_S3_SECRET_KEY=your-secret-key

# 键前缀（可选，用于在桶内分区）
# OPENTOKEN_S3_PREFIX=opentoken/

# ========================================
# 状态目录配置（仅本地存储时有效）
# ========================================
# 自定义状态目录（默认: ~/.opentoken）
# OPENTOKEN_STATE_DIR=/data/opentoken

# ========================================
# 代理配置（可选）
# ========================================
# HTTP_PROXY=http://your-proxy:7890
# HTTPS_PROXY=http://your-proxy:7890
# NO_PROXY=localhost,127.0.0.1
