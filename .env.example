# OpenToken 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ========================================
# 网关 API Key 配置
# ========================================
# 优先从环境变量读取，不存在时自动生成并打印到日志
# OPENTOKEN_API_KEY=your-api-key-here

# ========================================
# 网关绑定配置
# ========================================
# 绑定地址（默认: 容器环境自动检测为 0.0.0.0，本地环境为 127.0.0.1）
# OPENTOKEN_HOST=0.0.0.0

# 绑定端口（默认: 32117，容器环境也会自动读取 PORT 变量）
# OPENTOKEN_PORT=32117

# ========================================
# 存储后端配置
# ========================================
# 存储后端类型: "local" (默认) 或 "s3"
OPENTOKEN_STORAGE_BACKEND=local

# ========================================
# S3 兼容对象存储配置（当 OPENTOKEN_STORAGE_BACKEND=s3 时需要）
# ========================================
# S3 端点 URL（可选，根据实际情况填写）
# OPENTOKEN_S3_ENDPOINT=http://localhost:9000

# S3 区域（默认: us-east-1）
# OPENTOKEN_S3_REGION=us-east-1

# 存储桶名称（必填）
# OPENTOKEN_S3_BUCKET=opentoken-data

# Access Key ID（必填）
# OPENTOKEN_S3_ACCESS_KEY=your-access-key

# Secret Access Key（必填）
# OPENTOKEN_S3_SECRET_KEY=your-secret-key

# 键前缀（可选，用于在桶内分区）
# OPENTOKEN_S3_PREFIX=opentoken/

# ----------------------------------------
# S3 高级配置（可选）
# ----------------------------------------
# 签名版本（默认: s3v4，兼容大多数 S3 兼容服务）
# OPENTOKEN_S3_SIGNATURE_VERSION=s3v4

# 寻址样式（默认: path，兼容华为云等国产 S3；AWS S3/Cloudflare R2 使用 virtual）
# 不同 S3 服务推荐配置：
#   - AWS S3 / Cloudflare R2 / 阿里云 OSS / 腾讯云 COS: virtual
#   - 华为云 OBS / MinIO: path
# OPENTOKEN_S3_ADDRESSING_STYLE=path

# 内容签名（默认: false，禁用可解决 XAmzContentSHA256Mismatch 错误）
# OPENTOKEN_S3_PAYLOAD_SIGNING=false

# ========================================
# 状态目录配置（仅本地存储时有效）
# ========================================
# 自定义状态目录（默认: ~/.opentoken）
# OPENTOKEN_STATE_DIR=/data/opentoken

# ========================================
# 代理配置（可选）
# ========================================
# HTTP_PROXY=http://your-proxy:7890
# HTTPS_PROXY=http://your-proxy:7890
# NO_PROXY=localhost,127.0.0.1
